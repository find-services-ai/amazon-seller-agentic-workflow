# === LLM Configuration ===
# Choose provider: github (free), openai, anthropic, or gemini
LLM_PROVIDER=gemini

# Gemini (Google AI) — recommended
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
GEMINI_THINKING_MODEL=gemini-2.5-pro-preview-05-06

# GitHub Models (FREE) — uses your GitHub PAT
# Get token at: https://github.com/settings/tokens (needs no special scopes for Models)
# Available models: gpt-4o-mini, gpt-4o, meta-llama-3.1-8b-instruct, mistral-small, phi-4
GITHUB_TOKEN=ghp_...
GITHUB_MODEL=gpt-4o-mini

# GitHub repo (for Actions-based agent workflows)
GITHUB_OWNER=cc-agent
GITHUB_REPO=amazon-seller-agentic-workflow

# OpenAI (paid alternative) — get key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Anthropic (paid alternative) — get key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === Server ===
PORT=3001

# === Auth ===
JWT_SECRET=change-this-to-a-random-string
SESSION_HOURS=72

# === MCP Bridge (optional — for Sheets/Gmail from backend) ===
MCP_SERVER_URL=http://localhost:8000
