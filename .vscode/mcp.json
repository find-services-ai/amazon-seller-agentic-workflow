{
  "mcpServers": {
    "google-workspace": {
      "command": "uvx",
      "args": ["workspace-mcp", "--tool-tier", "core", "--single-user", "--tools", "gmail", "sheets", "drive"],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "${env:GOOGLE_OAUTH_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${env:GOOGLE_OAUTH_CLIENT_SECRET}",
        "OAUTHLIB_INSECURE_TRANSPORT": "1"
      },
      "disabled": false,
      "description": "Google Workspace MCP (2K+ stars) — Gmail, Sheets, Drive via established agentic pattern with Desktop OAuth"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@anthropics/mcp-filesystem", "${workspaceFolder}/active-deals"],
      "disabled": false,
      "description": "Read/write deal files, templates, and tracking data"
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@anthropics/mcp-fetch"],
      "disabled": false,
      "description": "Fetch supplier listings, Amazon data, market research"
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@anthropics/mcp-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${env:SLACK_BOT_TOKEN}"
      },
      "disabled": true,
      "description": "Notify on new quotes, approvals needed, order updates"
    },
    "amazon-ads": {
      "command": "npx",
      "args": ["-y", "@marketplaceadpros/amazon-ads-mcp-server"],
      "env": {
        "BEARER_TOKEN": "${env:AMAZON_ADS_BEARER_TOKEN}"
      },
      "disabled": true,
      "description": "Amazon Advertising campaigns via MarketplaceAdPros MCP"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-playwright"],
      "disabled": true,
      "description": "Browser automation for Amazon Seller Central operations"
    }
  }
}
